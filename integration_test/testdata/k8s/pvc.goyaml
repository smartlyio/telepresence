{{- /*gotype: github.com/telepresenceio/telepresence/v2/integration_test/itest.PersistentVolumeClaim*/ -}}
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ .Name }}
  labels:
    purpose: tp-cli-testing
{{- with .Annotations }}
  annotations:
  {{- toYaml . | nindent 4 }}
{{- end }}
spec:
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: 0.1Gi
{{- with .StorageClassName }}
  storageClassName: {{ . }}
{{- end }}
