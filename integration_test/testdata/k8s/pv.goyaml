{{- /*gotype: github.com/telepresenceio/telepresence/v2/integration_test/itest.PersistentVolume*/ -}}
apiVersion: v1
kind: PersistentVolume
metadata:
  name: {{ .Name }}
  labels:
    purpose: tp-cli-testing
{{- with .Annotations }}
  annotations:
  {{- toYaml . | nindent 4 }}
{{- end }}
spec:
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
          - key: kubernetes.io/os
            operator: In
            values:
            - linux
  capacity:
    storage: 0.1Gi
  accessModes:
  - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  hostPath:
    path: /tmp/{{ .Name }}-pv
{{- with .StorageClassName }}
  storageClassName: {{ . }}
{{- end }}
